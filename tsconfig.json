{
	"compilerOptions": {
		"target": "esnext",
		"module": "esnext",
		"lib": [
			"esnext",
			"DOM"
		],
		"plugins": [
			{
				"name": "typescript-plugin-css-modules"
			}
		],
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,

		"allowJs": false,
		"skipLibCheck": true,

		"moduleResolution": "Bundler",
		// TODO(types): ui-sdk ships these components as source .vue only (no compiled
		// dist), so their "types" export condition is dangling and vue-tsc would
		// type-check the SDK sources. Point TS at the shipped .vue.d.ts instead.
		"paths": {
			"@webitel/ui-sdk/src/modules/UploadCsvPopup/components/wt-upload-csv-popup.vue": [
				"./node_modules/@webitel/ui-sdk/types/modules/UploadCsvPopup/components/wt-upload-csv-popup.vue.d.ts"
			],
			"@webitel/ui-sdk/components/on-demand/wt-upload-file-icon-btn/wt-upload-file-icon-btn.vue": [
				"./node_modules/@webitel/ui-sdk/types/components/on-demand/wt-upload-file-icon-btn/wt-upload-file-icon-btn.vue.d.ts"
			]
		},
		"isolatedModules": true,
		"moduleDetection": "force",
		"noEmit": true,
		"noEmitOnError": false,

		"strict": false,
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedSideEffectImports": true
	},
	"include": [
		"src",
		"node_modules/vite-plugin-checker/dist/esm/checkers/vueTsc/typescript-vue-tsc/lib/lib.dom.d.ts"
	]
}
